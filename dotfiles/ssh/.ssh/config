Host github.work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host github.personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/personal_key
    IdentitiesOnly yes

Host *.work.domain
    user some-user
    ForwardAgent yes
    CanonicalizeHostname yes
    CanonicalDomains work.domain
    CanonicalizeFallbackLocal yes
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    # Hack for ghostty
    SetEnv TERM=xterm-256color

Host github.com
    User git
    IdentitiesOnly yes
    ForwardAgent no

