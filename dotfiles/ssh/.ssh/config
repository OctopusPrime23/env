
Host *.domain
    user some_user
    ForwardAgent yes
    CanonicalizeHostname yes
    CanonicalDomains domain.com
    CanonicalizeFallbackLocal yes
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host github.work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host github.personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/personal_key
    IdentitiesOnly yes
